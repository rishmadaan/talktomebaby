{
  "name": "talktomebaby",
  "displayName": "TalkToMeBaby",
  "description": "Listen to your docs. Speechify-style reading for VS Code: word-level highlighting, click-to-jump, 2x speed without pitch shift.",
  "version": "0.3.0",
  "publisher": "rishmadaan",
  "icon": "icon.png",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/rishmadaan/talktomebaby" },
  "homepage": "https://marketplace.visualstudio.com/items?itemName=rishmadaan.talktomebaby",
  "bugs": { "url": "https://github.com/rishmadaan/talktomebaby/issues" },
  "galleryBanner": { "color": "#101828", "theme": "dark" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["tts", "text-to-speech", "read-aloud", "speechify", "highlight"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "talktomebaby.readDocument", "title": "TalkToMeBaby: Read Document", "icon": "$(unmute)" },
      { "command": "talktomebaby.readSelection", "title": "TalkToMeBaby: Read Selection" },
      { "command": "talktomebaby.readFromCursor", "title": "TalkToMeBaby: Read from Here" },
      { "command": "talktomebaby.jumpToCursor", "title": "TalkToMeBaby: Jump Playback to Cursor" },
      { "command": "talktomebaby.pauseResume", "title": "TalkToMeBaby: Pause/Resume" },
      { "command": "talktomebaby.stop", "title": "TalkToMeBaby: Stop" },
      { "command": "talktomebaby.openReader", "title": "TalkToMeBaby: Open Reader" },
      { "command": "talktomebaby.setApiKey", "title": "TalkToMeBaby: Set API Key" },
      { "command": "talktomebaby.selectProvider", "title": "TalkToMeBaby: Select TTS Provider" },
      { "command": "talktomebaby.selectVoice", "title": "TalkToMeBaby: Select Voice" }
    ],
    "menus": {
      "editor/title": [
        { "command": "talktomebaby.readDocument", "when": "resourceExtname =~ /\\.(md|mdx|txt|rst|org|tex|adoc)$/", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "talktomebaby.readFromCursor", "when": "resourceExtname =~ /\\.(md|mdx|txt|rst|org|tex|adoc)$/", "group": "navigation" },
        { "command": "talktomebaby.readSelection", "when": "editorHasSelection && resourceExtname =~ /\\.(md|mdx|txt|rst|org|tex|adoc)$/", "group": "navigation" }
      ]
    },
    "keybindings": [
      { "command": "talktomebaby.pauseResume", "key": "ctrl+shift+r", "mac": "cmd+shift+r" },
      { "command": "talktomebaby.jumpToCursor", "key": "alt+j", "mac": "alt+j", "when": "editorTextFocus" }
    ],
    "configuration": {
      "type": "object",
      "title": "TalkToMeBaby",
      "properties": {
        "talktomebaby.provider": {
          "type": "string", "default": "edge",
          "enum": ["edge", "elevenlabs", "say", "sarvam"],
          "enumDescriptions": [
            "Edge TTS (free, no key, word-level timing)",
            "ElevenLabs (premium voices, word-level timing, requires key)",
            "macOS say (offline, estimated timing, macOS only)",
            "Sarvam AI (Indian English, estimated timing, requires key)"
          ],
          "description": "TTS provider"
        },
        "talktomebaby.voice.edge": { "type": "string", "default": "en-US-AriaNeural" },
        "talktomebaby.voice.elevenlabs": { "type": "string", "default": "21m00Tcm4TlvDq8ikWAM" },
        "talktomebaby.voice.say": { "type": "string", "default": "Samantha" },
        "talktomebaby.voice.sarvam": { "type": "string", "default": "shubh" },
        "talktomebaby.speed": { "type": "number", "default": 1.0, "minimum": 0.5, "maximum": 2.0, "description": "Playback speed (pitch preserved). Persisted from the player." },
        "talktomebaby.editorClickToJump": {
          "type": "string", "default": "alt-j",
          "enum": ["off", "alt-j", "plain-click"],
          "description": "How to jump playback from the source editor: keyboard gesture on cursor (alt-j), or any plain mouse click during a session (plain-click). Jumping always starts playback from the clicked word, even when paused. Set to off to disable."
        },
        "talktomebaby.readerFontSize": { "type": "number", "default": 16 },
        "talktomebaby.highlight.sentenceColor": { "type": "string", "default": "", "description": "Sentence band color. Empty = theme default." },
        "talktomebaby.highlight.wordColor": { "type": "string", "default": "", "description": "Current word color. Empty = theme default." },
        "talktomebaby.cacheSizeMB": { "type": "number", "default": 200 }
      }
    }
  },
  "scripts": {
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "compile:webview": "esbuild src/webview/main.ts --bundle --outfile=media/reader.js --format=iife --sourcemap",
    "watch": "npm run compile:ext -- --watch & npm run compile:webview -- --watch",
    "build": "npm run compile:ext -- --minify && npm run compile:webview -- --minify",
    "test": "vitest run",
    "vscode:prepublish": "npm run build",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.10.2",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "msedge-tts": "^2.0.5"
  }
}
